  <template id="page_rentals" name="TechFlex TT Rentals">
    <t t-call="website.layout">
      <div id="wrap" class="tfx-site tfx-page-rentals">
        <section class="tfx-inner-hero tfx-rentals-hero">
          <div class="tfx-shell tfx-inner-hero-grid">
            <div>
              <span class="tfx-eyebrow">Corporate &amp; Event Rentals</span>
              <h1>Flexible tech rentals for teams, training, events and temporary workspaces.</h1>
              <p>Request laptops, desktops, tablets, projectors, monitors and accessories with a clean process built around your rental dates, specifications and support needs.</p>
            </div>
            <div class="tfx-inner-hero-card">
              <strong>1–65 units</strong>
              <span>Available per rental request</span>
            </div>
          </div>
        </section>

        <section class="tfx-section tfx-rental-main" id="rental-form">
          <div class="tfx-shell tfx-rental-layout">
            <div class="tfx-form-panel">
              <span class="tfx-kicker">Rental request form</span>
              <h2>Tell us what your project needs.</h2>
              <p class="tfx-form-intro">Complete the form below and the TechFlex TT team will get back to you with availability and a custom rental solution.</p>
              <form class="tfx-form" action="/tech-rentals/submit" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="tfx-form-row three">
                  <label>First Name *<input name="first_name" required="required" type="text"/></label>
                  <label>Last Name *<input name="last_name" required="required" type="text"/></label>
                  <label>Company Name<input name="company_name" type="text"/></label>
                </div>
                <div class="tfx-form-row two">
                  <label>Email Address *<input name="email" required="required" type="email"/></label>
                  <label>Phone Number *<input name="phone" required="required" type="tel"/></label>
                </div>
                <label>Business Address<textarea name="business_address" rows="3"></textarea></label>
                <fieldset>
                  <legend>Equipment Required *</legend>
                  <div class="tfx-check-grid">
                    <label><input type="checkbox" name="equipment" value="Desktops"/> Desktops</label>
                    <label><input type="checkbox" name="equipment" value="Laptops"/> Laptops</label>
                    <label><input type="checkbox" name="equipment" value="Tablets"/> Tablets</label>
                    <label><input type="checkbox" name="equipment" value="TVs / Monitors"/> TVs / Monitors</label>
                    <label><input type="checkbox" name="equipment" value="Projectors"/> Projectors</label>
                    <label><input type="checkbox" name="equipment" value="Printers"/> Printers</label>
                    <label><input type="checkbox" name="equipment" value="Accessories / Peripherals"/> Accessories / Peripherals</label>
                    <label><input type="checkbox" name="equipment" value="Other"/> Other</label>
                  </div>
                </fieldset>
                <fieldset>
                  <legend>Specification Level *</legend>
                  <div class="tfx-radio-row">
                    <label><input type="radio" name="spec_level" value="Basic" required="required"/> Basic</label>
                    <label><input type="radio" name="spec_level" value="Mid Range"/> Mid Range</label>
                    <label><input type="radio" name="spec_level" value="High End"/> High End</label>
                  </div>
                </fieldset>
                <div class="tfx-form-row three">
                  <label>Number of Units *<select name="units" required="required"><option value="">Select number of units</option><option>1-5</option><option>6-15</option><option>16-30</option><option>31-65</option></select></label>
                  <label>Rental Start Date *<input name="start_date" required="required" type="date"/></label>
                  <label>Rental End / Duration *<input name="end_date" required="required" type="text" placeholder="Date or duration"/></label>
                </div>
                <label>Pickup or Delivery *<select name="fulfillment" required="required"><option value="">Select an option</option><option>Pickup</option><option>Delivery</option><option>Not sure yet</option></select></label>
                <label>Additional Information / Requirements<textarea name="message" rows="5" placeholder="Tell us about the event, location, software needs, setup support or other requirements."></textarea></label>
                <button class="tfx-btn tfx-btn-blue" type="submit">Submit Request</button>
              </form>
            </div>
            <aside class="tfx-rental-side">
              <img src="/techflex_tt_brand_site/static/src/img/rental-panel.svg" alt="TechFlex long term and short term rentals"/>
              <div class="tfx-faq-box" id="faq">
                <span class="tfx-kicker">FAQ</span>
                <h3>Rental Questions</h3>
                <details><summary>What types of equipment are available for rent?</summary><p>Laptops, desktops, tablets, TVs, monitors, projectors, printers and accessories.</p></details>
                <details><summary>What is the minimum and maximum number of units?</summary><p>Rental quantity depends on availability. This form supports requests from 1 to 65 units.</p></details>
                <details><summary>Do you offer delivery and pickup?</summary><p>Pickup and delivery can be discussed based on your location, timing and package size.</p></details>
                <details><summary>Is technical support available?</summary><p>Yes. Support can be included depending on your rental needs and event requirements.</p></details>
              </div>
            </aside>
          </div>
        </section>

        <section class="tfx-section tfx-rental-cats">
          <div class="tfx-shell">
            <div class="tfx-section-head compact"><span class="tfx-kicker">Rental categories</span><h2>Build the right package.</h2></div>
            <div class="tfx-card-grid tfx-category-grid">
              <div class="tfx-category-card"><strong>Laptops</strong><span>Training, teams, remote work</span></div>
              <div class="tfx-category-card"><strong>Desktops</strong><span>Temporary office stations</span></div>
              <div class="tfx-category-card"><strong>Tablets</strong><span>Check-in, events, mobile teams</span></div>
              <div class="tfx-category-card"><strong>Projectors</strong><span>Presentations and conferences</span></div>
              <div class="tfx-category-card"><strong>Displays</strong><span>Meetings, booths and signage</span></div>
              <div class="tfx-category-card"><strong>Accessories</strong><span>Keyboards, mice, cables and more</span></div>
            </div>
          </div>
        </section>
        <t t-call="techflex_tt_brand_site.shared_cta"/>
      </div>
    </t>
  </template>

