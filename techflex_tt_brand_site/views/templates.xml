  <template id="page_rentals" name="TechFlex TT Rentals">
    <t t-call="website.layout">
      <t t-call="techflex_tt_brand_site.svg_icons"/>
      <div id="wrap" class="tfx-site tfx-inner-page">
        <section class="tfx-page-hero tfx-rentals-hero">
          <div class="tfx-shell tfx-page-hero-inner">
            <span class="tfx-eyebrow">Tech Rentals</span>
            <h1>Flexible equipment rentals for teams, events and temporary workspaces.</h1>
            <p>Request laptops, desktops, tablets, displays, projectors, networking equipment and accessories with a smooth process built around your dates, location and support needs.</p>
          </div>
        </section>
        <section class="tfx-section tfx-rental-categories">
          <div class="tfx-shell">
            <div class="tfx-section-head tfx-centered"><span class="tfx-kicker">Rental categories</span><h2>Reliable equipment for every <span>setup.</span></h2></div>
            <div class="tfx-rental-card-grid wide">
              <article id="rental-laptops" class="tfx-rental-card"><img src="/techflex_tt_brand_site/static/src/img/rental-laptop.webp" alt="Laptop rentals"/><h3>Laptops &amp; Desktops</h3><p>Training, remote work, temporary offices and business teams.</p></article>
              <article id="rental-projectors" class="tfx-rental-card"><img src="/techflex_tt_brand_site/static/src/img/rental-projector.webp" alt="Projector rentals"/><h3>Projectors &amp; Displays</h3><p>Presentations, meetings, conferences and classroom setups.</p></article>
              <article id="rental-networking" class="tfx-rental-card"><img src="/techflex_tt_brand_site/static/src/img/rental-network.webp" alt="Networking equipment rentals"/><h3>Networking Equipment</h3><p>Routers, connectivity support and temporary event networks.</p></article>
              <article id="rental-event" class="tfx-rental-card"><img src="/techflex_tt_brand_site/static/src/img/rental-event.webp" alt="Event technology rentals"/><h3>Event Technology</h3><p>Technology packages for shows, launches, activations and events.</p></article>
            </div>
          </div>
        </section>
        <section class="tfx-section tfx-rental-main" id="rental-form">
          <div class="tfx-shell tfx-rental-layout">
            <aside class="tfx-form-aside">
              <span class="tfx-kicker">Rental request</span>
              <h2>Tell us what your project needs.</h2>
              <p>Submit your rental details and our team will contact you with availability, recommendations and next steps.</p>
              <div class="tfx-aside-list"><span>Flexible periods</span><span>Pickup or delivery options</span><span>Corporate and event packages</span><span>Support during rental</span></div>
            </aside>
            <div class="tfx-form-panel">
              <form class="tfx-form" action="/tech-rentals/submit" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="tfx-form-row three"><label>First Name *<input name="first_name" required="required" type="text"/></label><label>Last Name *<input name="last_name" required="required" type="text"/></label><label>Company Name<input name="company_name" type="text"/></label></div>
                <div class="tfx-form-row two"><label>Email Address *<input name="email" required="required" type="email"/></label><label>Phone Number *<input name="phone" required="required" type="tel"/></label></div>
                <label>Business Address<textarea name="business_address" rows="3"></textarea></label>
